# Set these in the Coolify service env tab.

# Comma-separated list of targets (must include scheme).
TARGETS=https://expediotechnologies.com,https://admin.expediotechnologies.com,https://dashboard.expediotechnologies.com

# Nuclei severity filter. Use "info,low,medium,high,critical" for everything.
SEVERITY=medium,high,critical

# Run a scan immediately when the scanner container starts.
SCAN_ON_START=true

# Cron schedule for recurring scans. Default = weekly, Sunday 03:00 UTC.
SCAN_CRON=0 3 * * 0

# ZAP mode: "baseline" (passive, ~2 min, prod-safe) or "full" (active, hours, only sites you own).
ZAP_MODE=baseline

# Reports site basic auth.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=replace-me-with-something-strong
